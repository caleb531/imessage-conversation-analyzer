{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iMessage Conversation Analyzer",
  "version": "0.1.0",
  "identifier": "com.calebevans.imessage-conversation-analyzer",
  "build": {
    "beforeDevCommand": "vite dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "iMessage Conversation Analyzer",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"],
        "object-src": ["'none'"],
        "frame-ancestors": ["'none'"],
        "script-src": ["'self'"],
        "style-src": ["'self'"],
        "img-src": ["'self'", "data:"],
        "font-src": ["'self'"],
        "connect-src": ["'self'", "ipc:", "https://ipc.localhost", "http://ipc.localhost"],
        "frame-src": ["'none'"],
        "worker-src": ["'self'"]
      },
      "devCsp": {
        "default-src": [
          "'self'",
          "http://localhost:1420",
          "http://127.0.0.1:1420",
          "ws://localhost:1421",
          "ws://127.0.0.1:1421"
        ],
        "base-uri": ["'self'"],
        "form-action": ["'self'"],
        "object-src": ["'none'"],
        "frame-ancestors": ["'none'"],
        "script-src": [
          "'self'",
          "'unsafe-inline'",
          "'unsafe-eval'",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "img-src": [
          "'self'",
          "data:",
          "asset:",
          "https://asset.localhost",
          "http://asset.localhost",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "font-src": ["'self'", "http://localhost:1420", "http://127.0.0.1:1420"],
        "connect-src": [
          "'self'",
          "ipc:",
          "https://ipc.localhost",
          "http://ipc.localhost",
          "http://localhost:1420",
          "http://127.0.0.1:1420",
          "ws://localhost:1421",
          "ws://127.0.0.1:1421"
        ]
      }
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/ica-sidecar"],
    "resources": ["_internal"]
  }
}
